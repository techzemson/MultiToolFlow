{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the MultiToolFlow platform.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "role": { "type": "string", "enum": ["user", "admin"] }
      },
      "required": ["email", "createdAt", "role"]
    },
    "ToolUsage": {
      "title": "ToolUsage",
      "description": "Records of tools used by the user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "toolId": { "type": "string" },
        "usedAt": { "type": "string", "format": "date-time" },
        "metadata": { "type": "object" }
      },
      "required": ["userId", "toolId", "usedAt"]
    },
    "SavedReport": {
      "title": "SavedReport",
      "description": "Saved reports generated by tools (e.g., Amazon PPC).",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "toolId": { "type": "string" },
        "name": { "type": "string" },
        "data": { "type": "string", "description": "JSON stringified report data" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "toolId", "name", "data", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/toolUsages/{usageId}": {
      "schema": { "$ref": "#/entities/ToolUsage" },
      "description": "Tool usage logs"
    },
    "/savedReports/{reportId}": {
      "schema": { "$ref": "#/entities/SavedReport" },
      "description": "Saved reports for users"
    }
  }
}
